---
import { getCollection, getEntry, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { uploadPath, withBase } from "../../lib/site";

export async function getStaticPaths() {
  const newsEntries = await getCollection("news");
  return newsEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { slug: entry.slug },
  }));
}

const { slug } = Astro.props;
const base = import.meta.env.BASE_URL;
const entry = await getEntry("news", slug);

if (!entry) {
  throw new Error(`News article not found for slug: ${slug}`);
}

const { Content } = await render(entry);
const allEntries = (await getCollection("news"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentEntries = allEntries.filter((item) => item.id !== entry.id).slice(0, 3);

const assetPath = (path = "") => uploadPath(base, path);
const newsLink = (s = "") => withBase(base, `news/${s}`);

const formatDate = (date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<style>
  .wrap{
    max-width: 980px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem;
  }
  
  /* Combined Hero Styling */
  .hero {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr; /* Image and text side-by-side */
    align-items: stretch;
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    overflow: hidden; /* Clips the image to the border radius */
  }

  .heroImageContainer {
    width: 100%;
    height: 100%;
    min-height: 320px;
    background: #f0f0f0;
  }

  .heroImageContainer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .heroContent {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .kicker {
    margin: 0 0 .55rem;
    font-size: .9rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(56,189,248, 1); /* Accent color */
    font-weight: 600;
  }

  h1 {
    margin: 0;
    font-size: 2.4rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #111;
  }

  .meta {
    margin-top: .8rem;
    color: rgba(0,0,0,.5);
    font-size: .9rem;
  }

  .summary {
    margin: 1.2rem 0 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(0,0,0,.7);
  }

  /* Article & Recent Cards */
  .article, .recentCard {
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
  }

  .article {
    margin-top: 1.25rem;
    padding: 2rem;
  }

  .article :global(p) {
    margin: 0 0 1.2rem;
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(0,0,0,.8);
  }

  .backLink {
    display: inline-flex;
    margin-top: 1.5rem;
    text-decoration: none;
    color: #333;
    font-weight: 700;
    border-bottom: 2px solid transparent;
  }
  .backLink:hover { border-color: currentColor; }

  .recentSection { margin-top: 2rem; }
  .recentGrid {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .recentCard { padding: 1.2rem; }
  .recentCard a { text-decoration: none; color: inherit; }
  .recentCard h2 { margin: 0; font-size: 1.1rem; line-height: 1.3; }
  .recentCard a:hover h2 { text-decoration: underline; }

  /* Responsive Adjustments */
  @media (max-width: 850px) {
    .hero { grid-template-columns: 1fr; } /* Stack on mobile */
    .heroImageContainer { height: 250px; min-height: auto; }
    .recentGrid { grid-template-columns: 1fr; }
  }
</style>

<SiteLayout title={`${entry.data.title} | News`}>
  <main class="wrap">
    
    <article class="hero">
      {entry.data.heroImage && (
        <div class="heroImageContainer">
          <img 
            src={assetPath(entry.data.heroImage)} 
            alt={entry.data.heroAlt ?? entry.data.title} 
            loading="eager" 
          />
        </div>
      )}
      
      <div class="heroContent">
        <p class="kicker">{entry.data.category ?? "News"}</p>
        <h1>{entry.data.title}</h1>
        <div class="meta">
          <span>{formatDate(entry.data.publishedAt)}</span>
          {entry.data.updatedAt && <span> • Updated {formatDate(entry.data.updatedAt)}</span>}
        </div>
        <p class="summary">{entry.data.summary}</p>
      </div>
    </article>

    <section class="article">
      <Content />
      <a class="backLink" href={withBase(base, "news")}>← Back to all news</a>
    </section>

    {recentEntries.length > 0 && (
      <section class="recentSection" aria-label="Recent news">
        <div class="recentGrid">
          {recentEntries.map((item) => (
            <article class="recentCard">
              <a href={newsLink(item.slug)}>
                <h2>{item.data.title}</h2>
              </a>
              <div class="meta" style="margin-top: 0.5rem;">
                <span>{formatDate(item.data.publishedAt)}</span>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </main>
</SiteLayout>
