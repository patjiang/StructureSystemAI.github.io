---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { withBase as withSiteBase } from "../../lib/site";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);

const projectEntries = await getCollection("projects");

const stats = [
  { label: "Active Projects", value: String(projectEntries.length) },
  { label: "Research Areas", value: "6+" },
  { label: "Team Members", value: "10+" },
  { label: "Partner Sites", value: "Multi-site" },
];
---

<style>
  :global(html) { font-family: Arial, Helvetica, sans-serif; }
  :global(body) { background: #f6f7fb; margin: 0; color: rgba(0,0,0,.9); }

  .wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.25rem 1.25rem 3rem 1.25rem;
  }

  .hero {
    border-radius: 26px;
    padding: 2.6rem 2rem;
    background:
      radial-gradient(1200px 420px at 12% 10%, rgba(99,102,241,.24), transparent 60%),
      radial-gradient(900px 420px at 90% 0%, rgba(56,189,248,.20), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.74));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    margin-bottom: 2rem;
  }

  .heroGrid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1.3fr .9fr;
    align-items: center;
  }

  .kicker {
    font-size: 0.92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem 0;
  }

  h1 {
    font-size: 3rem;
    line-height: 1.04;
    margin: 0 0 .8rem 0;
    letter-spacing: -0.02em;
  }

  .sub {
    font-size: 1.16rem;
    line-height: 1.6;
    color: rgba(0,0,0,.72);
    max-width: 66ch;
    margin: 0;
  }

  .heroButtons {
    display: flex;
    gap: .8rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .82rem 1.1rem;
    border-radius: 18px;
    text-decoration: none;
    font-weight: 700;
    font-size: .98rem;
    border: 1px solid rgba(0,0,0,.10);
    transition: transform .15s ease, background .15s ease;
  }

  .btn:hover { transform: translateY(-1px); }
  .btnPrimary {
    background: #111827;
    color: white;
    border-color: #111827;
  }
  .btnSecondary {
    background: white;
    color: #111827;
  }

  .statsGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
  }

  .statCard {
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 24px rgba(0,0,0,.06);
    padding: 1rem;
  }

  .statLabel {
    font-size: .92rem;
    color: rgba(0,0,0,.55);
    margin: 0 0 .35rem 0;
  }

  .statValue {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .section {
    margin-top: 1.7rem;
  }

  .projectsGrid {
    display: grid;
    gap: 1.25rem;
  }

  .projectCard {
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.5rem;
  }

  .projectGrid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1.1fr .9fr;
  }

  .statusRow {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: .8rem;
  }

  .badge {
    border-radius: 999px;
    padding: .42rem .8rem;
    font-size: .9rem;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.03);
    font-weight: 700;
  }

  .badgeActive {
    background: #ecfdf5;
    border-color: #bbf7d0;
    color: #047857;
  }

  .projectTitle {
    margin: 0;
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .projectText {
    margin: .85rem 0 0 0;
    color: rgba(0,0,0,.7);
    line-height: 1.7;
    font-size: 1rem;
  }

  .tagRow {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: 1rem;
  }

  .tag {
    border-radius: 999px;
    padding: .38rem .75rem;
    font-size: .9rem;
    border: 1px solid rgba(0,0,0,.08);
    background: white;
    color: rgba(0,0,0,.72);
  }

  .metaGrid {
    display: grid;
    gap: .8rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .metaCard,
  .sideCard {
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,.06);
    background: rgba(0,0,0,.02);
    padding: 1rem;
  }

  .metaLabel,
  .sideLabel {
    margin: 0;
    font-size: .88rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(0,0,0,.5);
    font-weight: 700;
  }

  .metaValue {
    margin: .45rem 0 0 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .sideStack {
    display: grid;
    gap: .9rem;
  }

  .memberLink {
    display: block;
    text-decoration: none;
    border-radius: 16px;
    padding: .85rem 1rem;
    background: white;
    border: 1px solid rgba(0,0,0,.07);
    transition: transform .15s ease, background .15s ease;
  }

  .memberLink:hover {
    transform: translateY(-1px);
    background: rgba(0,0,0,.02);
  }

  .memberName {
    margin: 0;
    font-size: .98rem;
    font-weight: 700;
    color: rgba(0,0,0,.88);
  }

  .memberRole {
    margin: .25rem 0 0 0;
    color: rgba(0,0,0,.62);
    font-size: .93rem;
  }

  .progressList {
    margin: .7rem 0 0 0;
    padding-left: 1.1rem;
    color: rgba(0,0,0,.68);
    line-height: 1.7;
  }

  @media (max-width: 1000px) {
    .heroGrid,
    .projectGrid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    h1 { font-size: 2.3rem; }
    .hero { padding: 2rem 1.2rem; }
    .wrap { padding: 1.5rem 1rem 2.2rem 1rem; }
    .statsGrid,
    .metaGrid {
      grid-template-columns: 1fr;
    }
  }
</style>

<SiteLayout title="Projects | Systems Structural Biology Group">
  <main class="wrap">
    <section class="hero">
      <div class="heroGrid">
        <div>
          <p class="kicker">Systems Structural Biology Group</p>
          <h1>Active Projects</h1>
          <p class="sub">
            A shared view of ongoing research, current progress, and project teams.
          </p>
          <div class="heroButtons">
            <a href="#projects" class="btn btnPrimary">Browse projects</a>
            <a href={withBase("people")} class="btn btnSecondary">View people</a>
          </div>
        </div>

        <div class="statsGrid">
          {stats.map((stat) => (
            <div class="statCard">
              <p class="statLabel">{stat.label}</p>
              <p class="statValue">{stat.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="section">
      <div class="projectsGrid">
        {projectEntries.map((project) => (
          <article class="projectCard" id={project.id}>
            <div class="projectGrid">
              <div>
                <div class="statusRow">
                  <span class={`badge ${project.data.status === 'Active' ? 'badgeActive' : ''}`}>
                    {project.data.status}
                  </span>
                  <span class="badge">{project.data.phase}</span>
                </div>

                <h2 class="projectTitle">{project.data.title}</h2>
                <p class="projectText">{project.data.summary}</p>

                {project.data.tags && (
                  <div class="tagRow">
                    {project.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}

                <div class="metaGrid">
                  <div class="metaCard">
                    <p class="metaLabel">Timeline</p>
                    <p class="metaValue">{project.data.timeline}</p>
                  </div>
                  <div class="metaCard">
                    <p class="metaLabel">Lead</p>
                    <p class="metaValue">{project.data.lead}</p>
                  </div>
                </div>
              </div>

              <div class="sideStack">
                <div class="sideCard">
                  <p class="sideLabel">Team members</p>
                  <div style="margin-top:.8rem; display:grid; gap:.65rem;">
                    {project.data.team.map((member) => (
                      <a href={withBase(member.href)} class="memberLink">
                        <p class="memberName">{member.name}</p>
                        <p class="memberRole">{member.role}</p>
                      </a>
                    ))}
                  </div>
                </div>

                {project.data.updates && project.data.updates.length > 0 && (
                  <div class="sideCard">
                    <p class="sideLabel">Recent progress</p>
                    <ul class="progressList">
                      {project.data.updates.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>
