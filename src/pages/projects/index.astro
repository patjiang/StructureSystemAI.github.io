---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { withBase as withSiteBase } from "../../lib/site";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);

// Fetching from content collections (Dynamic approach)
const projectEntries = await getCollection("projects");

const topicDefinitions = [
  {
    slug: "structural-biology",
    label: "Structural Biology",
    matchTags: ["Structural Biology", "Biophysics", "Structure Prediction", "Electrostatics"],
  },
  {
    slug: "complex-systems",
    label: "Complex Systems",
    matchTags: ["Complex Systems", "Molecular Dynamics", "Brownian Dynamics", "Thermodynamic Ensembles", "MELD"],
  },
  {
    slug: "multiscale-modeling",
    label: "Multiscale Modeling",
    matchTags: ["Multiscale Modeling", "Molecular Dynamics", "Brownian Dynamics", "MELD", "Thermodynamic Ensembles"],
  },
  {
    slug: "applied-deep-learning",
    label: "Applied Deep Learning",
    matchTags: ["Applied Deep Learning", "Deep Learning", "SE3 Convolutional Networks"],
  },
  {
    slug: "human-computer-interaction",
    label: "Human Computer Interaction",
    matchTags: ["Human Computer Interaction", "STEM Education"],
  },
];

const tagMatchesTopic = (tag = "", topic) => {
  const normalizedTag = tag.toLowerCase();
  return topic.matchTags.some((matchTag) => normalizedTag.includes(matchTag.toLowerCase()));
};

const topicsForProject = (project) =>
  topicDefinitions.filter((topic) =>
    project.data.tags?.some((tag) => tagMatchesTopic(tag, topic))
  );

const projectTopicMap = Object.fromEntries(
  projectEntries.map((project) => [project.id, topicsForProject(project).map((topic) => topic.slug)])
);

const topicSummaries = topicDefinitions.map((topic) => {
  const projects = projectEntries.filter((project) => projectTopicMap[project.id]?.includes(topic.slug));
  const people = new Map();

  for (const project of projects) {
    for (const member of project.data.team ?? []) {
      people.set(member.name, member);
    }
  }

  return {
    ...topic,
    projects,
    people: Array.from(people.values()).sort((a, b) => a.name.localeCompare(b.name)),
  };
});

const stats = [
  { label: "Active Projects", value: String(projectEntries.length) },
  { label: "Research Areas", value: String(topicDefinitions.length) },
  { label: "Team Members", value: "10+" },
  { label: "Partner Sites", value: "Multi-site" },
];
---

<style>
  :global(html) { font-family: Arial, Helvetica, sans-serif; }
  :global(body) { background: #f6f7fb; margin: 0; color: rgba(0,0,0,.9); }

  .navWrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: .9rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.25rem 1.25rem 3rem 1.25rem;
  }

  .hero {
    border-radius: 26px;
    padding: 2.6rem 2rem;
    background:
      radial-gradient(1200px 420px at 12% 10%, rgba(99,102,241,.24), transparent 60%),
      radial-gradient(900px 420px at 90% 0%, rgba(56,189,248,.20), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.74));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    margin-bottom: 2rem;
  }

  .heroGrid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1.3fr .9fr;
    align-items: center;
  }

  .kicker {
    font-size: 0.92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem 0;
  }

  h1 {
    font-size: 3rem;
    line-height: 1.04;
    margin: 0 0 .8rem 0;
    letter-spacing: -0.02em;
  }

  .sub {
    font-size: 1.16rem;
    line-height: 1.6;
    color: rgba(0,0,0,.72);
    max-width: 66ch;
    margin: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .82rem 1.1rem;
    border-radius: 18px;
    text-decoration: none;
    font-weight: 700;
    background: #111827;
    color: white;
  }

  .statsGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
  }

  .statCard {
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    padding: 1rem;
  }

  .statValue {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
  }

  .topicMap {
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    padding: 1.3rem;
    margin-bottom: 2rem;
  }

  .topicPills {
    display: flex;
    flex-wrap: wrap;
    gap: .55rem;
    margin-top: 1rem;
  }

  .topicPill {
    border-radius: 999px;
    padding: .48rem .78rem;
    font-size: .92rem;
    text-decoration: none;
    border: 1px solid rgba(0,0,0,.10);
    background: white;
    color: rgba(0,0,0,.74);
  }

  .topicPill.active {
    background: #111827;
    color: white;
  }

  .topicResult {
    display: none;
    margin-top: 1.5rem;
    padding: 1rem;
    background: rgba(0,0,0,.02);
    border-radius: 20px;
  }

  .topicResult.active { display: block; }

  .topicResultGrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .projectsGrid {
    display: grid;
    gap: 1.25rem;
  }

  .projectCard {
    border-radius: 24px;
    background: white;
    border: 1px solid rgba(0,0,0,.06);
    padding: 1.5rem;
  }

  .projectCard.isHidden { display: none; }

  .projectGrid {
    display: grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 1.5rem;
  }

  .badge {
    border-radius: 999px;
    padding: .4rem .8rem;
    font-size: .85rem;
    font-weight: 700;
    background: #f3f4f6;
  }

  .badgeActive { background: #ecfdf5; color: #047857; }

  .mediaContainer video, .mediaContainer img {
    width: 100%;
    border-radius: 16px;
    margin-top: 1rem;
  }

  .publicationBlock {
    margin-top: 1rem;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 12px;
  }

  .memberLink {
    display: block;
    padding: .5rem;
    text-decoration: none;
    color: #111827;
    border-bottom: 1px solid #eee;
  }

  @media (max-width: 1000px) {
    .heroGrid, .projectGrid, .topicResultGrid { grid-template-columns: 1fr; }
  }
</style>

<SiteLayout title="Projects | Systems Structural Biology Group">
  <main class="wrap">
    <section class="hero">
      <div class="heroGrid">
        <div>
          <p class="kicker">Systems Structural Biology Group</p>
          <h1>Active Projects</h1>
          <p class="sub">Exploring the intersection of structural biology and human-centered AI.</p>
          <div style="margin-top: 1.5rem;">
            <a href="#projects" class="btn">Browse projects</a>
          </div>
        </div>
        <div class="statsGrid">
          {stats.map((stat) => (
            <div class="statCard">
              <p style="margin:0; font-size:.9rem; color:#666;">{stat.label}</p>
              <p class="statValue">{stat.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="topic-map" class="topicMap">
      <h2 style="margin:0;">Topic Map</h2>
      <p>Filter projects and people by research area:</p>
      <div class="topicPills">
        {topicSummaries.map((topic) => (
          <a class="topicPill" href={`?topic=${topic.slug}#topic-map`} data-topic-link={topic.slug} data-topic-label={topic.label}>
            {topic.label}
          </a>
        ))}
      </div>

      {topicSummaries.map((topic) => (
        <div class="topicResult" data-topic-result={topic.slug}>
          <div class="topicResultGrid">
            <div>
              <strong>Projects:</strong>
              {topic.projects.map(p => (
                <div style="margin-top:5px;"><a href={`#${p.id}`}>{p.data.title}</a></div>
              ))}
            </div>
            <div>
              <strong>People:</strong>
              {topic.people.map(person => (
                <div style="margin-top:5px;"><a href={withBase(person.href)}>{person.name}</a></div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </section>

    <div class="projectsGrid" id="projects">
      {projectEntries.map((project) => (
        <article class="projectCard" id={project.id} data-project-topics={projectTopicMap[project.id].join(" ")}>
          <div class="projectGrid">
            <div>
              <div style="margin-bottom: 10px;">
                <span class={`badge ${project.data.status === 'Active' ? 'badgeActive' : ''}`}>{project.data.status}</span>
                <span class="badge" style="margin-left: 5px;">{project.data.phase}</span>
              </div>
              <h2 style="margin:0;">{project.data.title}</h2>
              <p>{project.data.summary}</p>
              
              {(project.data.video || project.data.thumbnail) && (
                <div class="mediaContainer">
                  {project.data.video ? (
                    <video src={withBase(project.data.video)} controls muted loop playsinline />
                  ) : (
                    <img src={withBase(project.data.thumbnail)} alt={project.data.title} />
                  )}
                </div>
              )}
            </div>

            <div class="sideStack">
              <div class="statCard">
                <strong>Team</strong>
                {project.data.team.map((member) => (
                  <a href={withBase(member.href)} class="memberLink">{member.name} — <small>{member.role}</small></a>
                ))}
              </div>
              {project.data.updates && (
                <div class="statCard" style="margin-top:10px;">
                  <strong>Progress</strong>
                  <ul style="padding-left:20px; margin-top:5px;">
                    {project.data.updates.map(u => <li>{u}</li>)}
                  </ul>
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>

  <script>
    const topicLinks = Array.from(document.querySelectorAll("[data-topic-link]"));
    const topicResults = Array.from(document.querySelectorAll("[data-topic-result]"));
    const projectCards = Array.from(document.querySelectorAll("[data-project-topics]"));

    const showTopic = (topicSlug) => {
      topicLinks.forEach(l => l.classList.toggle("active", l.dataset.topicLink === topicSlug));
      topicResults.forEach(r => r.classList.toggle("active", r.dataset.topicResult === topicSlug));
      projectCards.forEach(c => {
        const topics = c.dataset.projectTopics.split(" ");
        c.classList.toggle("isHidden", !!topicSlug && !topics.includes(topicSlug));
      });
    };

    topicLinks.forEach(link => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const slug = link.dataset.topicLink;
        showTopic(slug);
        window.history.pushState({}, "", `?topic=${slug}#topic-map`);
      });
    });

    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has("topic")) showTopic(urlParams.get("topic"));
  </script>
</SiteLayout>
