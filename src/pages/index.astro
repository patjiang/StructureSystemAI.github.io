---
import SiteLayout from "../layouts/SiteLayout.astro";
import { withBase as withSiteBase } from "../lib/site";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);

const contactMethods = [
  {
    label: "Principal Investigator",
    value: "Abhishek Singharoy",
    detail: "asinghar@asu.edu",
    href: "mailto:asinghar@asu.edu",
  },
  {
    label: "General website inquiries",
    value: "Lab communications",
    detail: "Use email for collaboration, recruiting, or website questions.",
    href: "mailto:asinghar@asu.edu?subject=Lab%20Website%20Inquiry",
  },
];

const quickLinks = [
  { label: "People", href: withBase("/people") },
  { label: "Research", href: withBase("/research") },
  { label: "Projects", href: withBase("/projects") },
  { label: "News", href: withBase("/news") },
];
---

<style>
  .wrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem;
  }
  .hero{
    border-radius: 28px;
    padding: 2.6rem 2.2rem;
    background:
      radial-gradient(1200px 520px at 8% 0%, rgba(56,189,248,.22), transparent 55%),
      radial-gradient(900px 520px at 100% 0%, rgba(99,102,241,.20), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.95), rgba(255,255,255,.80));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 18px 46px rgba(0,0,0,.08);
  }
  .kicker{
    font-size: .92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem;
  }
  h1{
    margin: 0;
    font-size: 3rem;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .lead{
    margin: .9rem 0 0;
    max-width: 70ch;
    color: rgba(0,0,0,.72);
    line-height: 1.68;
    font-size: 1.15rem;
  }

  .grid{
    display:grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 1.2rem;
    margin-top: 1.3rem;
  }
  .stack{
    display:grid;
    gap: 1.2rem;
  }
  .card{
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.3rem;
  }
  .card h2{
    margin: 0 0 .8rem;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
  }
  .card p{
    margin: 0;
    color: rgba(0,0,0,.74);
    line-height: 1.7;
    font-size: 1.03rem;
  }
  .contactList{
    display:grid;
    gap: .9rem;
  }
  .contactItem{
    padding: 1rem;
    border-radius: 18px;
    background: rgba(0,0,0,.03);
    border: 1px solid rgba(0,0,0,.05);
  }
  .contactItem a{
    color: inherit;
    text-decoration: none;
  }
  .contactItem a:hover .contactValue{
    text-decoration: underline;
  }
  .contactLabel{
    margin: 0 0 .3rem;
    font-size: .9rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(0,0,0,.52);
  }
  .contactValue{
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: rgba(0,0,0,.9);
  }
  .contactDetail{
    margin-top: .35rem;
  }
  .linkGrid{
    display:grid;
    gap:.8rem;
    margin-top: .95rem;
  }
  .quickLink{
    display:flex;
    justify-content:space-between;
    align-items:center;
    text-decoration:none;
    color: rgba(0,0,0,.84);
    padding:.9rem 1rem;
    border-radius: 16px;
    background: rgba(255,255,255,.86);
    border: 1px solid rgba(0,0,0,.08);
  }
  .quickLink:hover{
    background: rgba(0,0,0,.03);
  }
  .btn{
    display:inline-flex;
    margin-top: 1rem;
    align-items:center;
    justify-content:center;
    text-decoration:none;
    font-weight:700;
    border-radius:999px;
    padding:.72rem 1.02rem;
    border:1px solid rgba(0,0,0,.10);
    background: rgba(0,0,0,.92);
    color: rgba(255,255,255,.96);
  }

  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
  }
  @media (max-width: 640px){
    .wrap{ padding: 1.6rem 1rem 2.8rem; }
    .hero{ padding: 2rem 1.35rem; }
    h1{ font-size: 2.3rem; }
  }
</style>

<SiteLayout title="Systems Structural Biology Group">
<main class="wrap">
  <section class="hero">
    <p class="kicker">Systems Structural Biology Group</p>
    <h1>Human-centered AI science for structural discovery and complex systems.</h1>
    <p class="lead">
      We build trustworthy computational methods that connect protein structure, molecular dynamics, and human decision-making. 
      Our tools span across structural biology, applied deep learning, and adaptive AI systems at the human-computer interface.
    </p>

    <div class="chips">
      <span class="chip">Structural biology</span>
      <span class="chip">Complex systems</span>
      <span class="chip">Human-centered data science</span>
      <span class="chip">Nonlinear dynamics</span>
      <span class="chip">Interpretable AI</span>
    </div>

    <div class="ctaRow">
      <a class="btn primary" href={`${base}research`}>Explore Research</a>
      <a class="btn" href={`${base}people`}>Meet the Team</a>
      <a class="btn" href={`${base}join`}>Join the Lab</a>
    </div>
  </section>

  <section class="grid" aria-label="Home content">
    <div class="card">
      <h2>What we do</h2>
      <p>
        We unify simulation, learning, and human-centered design to study complex biological and sociotechnical systems.
        Our work spans molecular modeling and structural analysis, data-driven inference, and adaptive decision support.
      </p>
      <ul class="list">
        <li><strong>Structural biology & modeling:</strong> molecular simulation, multiscale structure–function analysis.</li>
        <li><strong>AI + data science:</strong> statistical learning, reliable inference, uncertainty-aware modeling.</li>
        <li><strong>Complex systems:</strong> dynamical systems methods and interpretable metrics for behavior over time.</li>
        <li><strong>Human-centered AI:</strong> usable, trustworthy tools for learning, health, and operational contexts.</li>
      </ul>
    </div>

    <div class="mini">
      <div class="stat">
        <p class="label">Mission</p>
        <p class="value">Trustworthy, usable AI for discovery</p>
        <p class="desc">
          Build human-centered AI and data science that turns complex signals into reliable insight and deployable tools.
        </p>
      </div>

      <div class="stat">
        <p class="label">Vision</p>
        <p class="value">Interpretability at scale</p>
        <p class="desc">
          We hope to drive innovation by demistifying the underpinnings of complex AI/ML workflows and biological systems.
        </p>
      </div>

      <div class="stack">
        <article class="card">
          <h2>Quick links</h2>
          <p>
            If you are looking for a specific part of the site, these pages are usually the best starting points.
          </p>
          <div class="linkGrid">
            {quickLinks.map((item) => (
              <a class="quickLink" href={item.href}>
                <span>{item.label}</span>
                <span>Open</span>
              </a>
            ))}
          </div>
        </article>

        <article class="card">
          <h2>Primary email</h2>
          <p>
            For the fastest response, use email and include any relevant context or links in your first message.
          </p>
          <a class="btn" href="mailto:asinghar@asu.edu">asinghar@asu.edu</a>
        </article>
      </div>
    </section>
  </main>
</SiteLayout>
