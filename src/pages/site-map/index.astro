---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { withBase as withSiteBase } from "../../lib/site";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);

const siteMapGroups = [
  {
    title: "Explore",
    accent: "cyan",
    pages: [
      { label: "Home", href: withBase("/") },
      { label: "Research", href: withBase("/research") },
      { label: "Projects", href: withBase("/projects") },
    ],
  },
  {
    title: "People & Output",
    accent: "indigo",
    pages: [
      { label: "People", href: withBase("/people") },
      { label: "Publications", href: withBase("/publications") },
      { label: "News", href: withBase("/news") },
    ],
  },
  {
    title: "Connect",
    accent: "emerald",
    pages: [
      { label: "Join", href: withBase("/join") },
      { label: "Contact", href: withBase("/contact") },
      { label: "Site Map", href: withBase("/site-map") },
    ],
  },
];
---

<style>
  .wrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem;
  }

  .hero{
    border-radius: 28px;
    padding: 2.5rem 2.2rem;
    background:
      radial-gradient(1100px 520px at 10% 0%, rgba(34,197,94,.18), transparent 55%),
      radial-gradient(1000px 540px at 92% 6%, rgba(6,182,212,.18), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.95), rgba(255,255,255,.82));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 18px 46px rgba(0,0,0,.08);
  }

  .kicker{
    font-size: .92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem;
  }

  h1{
    margin: 0;
    font-size: 3rem;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }

  .lead{
    margin: .9rem 0 0;
    max-width: 72ch;
    color: rgba(0,0,0,.72);
    line-height: 1.65;
    font-size: 1.15rem;
  }

  .diagramShell{
    position: relative;
    margin-top: 1.35rem;
    padding: 1.4rem;
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.9), rgba(246,248,252,.92));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 14px 34px rgba(0,0,0,.06);
    overflow: hidden;
  }

  .diagramShell::before{
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,0,0,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,.03) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: .45;
    pointer-events: none;
  }

  .diagram{
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.2rem;
  }

  .rootWrap{
    display: grid;
    justify-items: center;
  }

  .rootNode{
    min-width: min(100%, 360px);
    text-align: center;
    border-radius: 24px;
    padding: 1.25rem 1.4rem;
    background:
      radial-gradient(circle at 20% 20%, rgba(59,130,246,.16), transparent 45%),
      radial-gradient(circle at 80% 30%, rgba(16,185,129,.18), transparent 45%),
      rgba(255,255,255,.96);
    border: 1px solid rgba(0,0,0,.08);
    box-shadow: 0 16px 36px rgba(0,0,0,.08);
  }

  .rootEyebrow{
    margin: 0 0 .35rem;
    font-size: .84rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: rgba(0,0,0,.48);
  }

  .rootTitle{
    margin: 0;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
  }

  .rootNote{
    margin: .45rem 0 0;
    font-size: .98rem;
    line-height: 1.55;
    color: rgba(0,0,0,.66);
  }

  .trunk{
    width: 2px;
    height: 44px;
    justify-self: center;
    background: linear-gradient(180deg, rgba(14,165,233,.48), rgba(16,185,129,.42));
    border-radius: 999px;
  }

  .branchGrid{
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
  }

  .branch{
    position: relative;
    border-radius: 24px;
    padding: 1.2rem;
    border: 1px solid rgba(0,0,0,.06);
    background: rgba(255,255,255,.94);
    box-shadow: 0 12px 28px rgba(0,0,0,.06);
  }

  .branch::before{
    content: "";
    position: absolute;
    top: -27px;
    left: 50%;
    width: 2px;
    height: 27px;
    transform: translateX(-50%);
    background: rgba(0,0,0,.10);
  }

  .branch[data-accent="cyan"]{
    background:
      radial-gradient(circle at 15% 15%, rgba(6,182,212,.16), transparent 38%),
      rgba(255,255,255,.94);
  }

  .branch[data-accent="indigo"]{
    background:
      radial-gradient(circle at 15% 15%, rgba(99,102,241,.16), transparent 38%),
      rgba(255,255,255,.94);
  }

  .branch[data-accent="emerald"]{
    background:
      radial-gradient(circle at 15% 15%, rgba(16,185,129,.16), transparent 38%),
      rgba(255,255,255,.94);
  }

  .branchTitle{
    margin: 0;
    font-size: 1.18rem;
    letter-spacing: -0.01em;
  }

  .branchList{
    display: grid;
    gap: .75rem;
    margin-top: .95rem;
  }

  .pageNode{
    display: block;
    text-decoration: none;
    color: rgba(0,0,0,.86);
    border-radius: 18px;
    padding: .95rem 1rem;
    background: rgba(0,0,0,.03);
    border: 1px solid rgba(0,0,0,.06);
    transition: transform .16s ease, border-color .16s ease, background .16s ease;
  }

  .pageNode:hover{
    transform: translateY(-1px);
    background: rgba(255,255,255,.95);
    border-color: rgba(0,0,0,.12);
  }

  .pageLabel{
    display: block;
    font-weight: 700;
    font-size: 1.02rem;
  }

  .pagePath{
    display: block;
    margin-top: .25rem;
    font-size: .9rem;
    color: rgba(0,0,0,.52);
  }

  .legend{
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: .65rem;
  }

  .legendItem{
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .5rem .72rem;
    border-radius: 999px;
    background: rgba(255,255,255,.86);
    border: 1px solid rgba(0,0,0,.08);
    color: rgba(0,0,0,.68);
    font-size: .92rem;
  }

  .legendSwatch{
    width: 10px;
    height: 10px;
    border-radius: 999px;
  }

  .legendSwatch.cyan{ background: #06b6d4; }
  .legendSwatch.indigo{ background: #6366f1; }
  .legendSwatch.emerald{ background: #10b981; }

  @media (max-width: 960px){
    .branchGrid{
      grid-template-columns: 1fr;
    }

    .branch::before{
      display: none;
    }

    .trunk{
      height: 24px;
    }
  }

  @media (max-width: 640px){
    .wrap{ padding: 1.6rem 1rem 2.8rem; }
    .hero{ padding: 2rem 1.35rem; }
    h1{ font-size: 2.3rem; }
    .lead{ font-size: 1.06rem; }
    .diagramShell{ padding: 1rem; }
  }
</style>

<SiteLayout title="Site Map | Systems Structural Biology Group">
  <main class="wrap">
    <section class="hero">
      <p class="kicker">Site Map</p>
      <h1>Visual guide to the lab website.</h1>
      <p class="lead">
        This diagram shows how the main pages connect, making it easier to scan the website structure
        before diving into people, projects, publications, or contact information.
      </p>
    </section>

    <section class="diagramShell" aria-labelledby="site-map-diagram-title">
      <div class="diagram">
        <div class="rootWrap">
          <div class="rootNode">
            <p class="rootEyebrow">Root</p>
            <h2 id="site-map-diagram-title" class="rootTitle">Systems Structural Biology Group</h2>
            <p class="rootNote">Main website entry point that branches into research, people, outputs, and ways to connect.</p>
          </div>
        </div>

        <div class="trunk" aria-hidden="true"></div>

        <div class="branchGrid">
          {siteMapGroups.map((group) => (
            <article class="branch" data-accent={group.accent}>
              <h3 class="branchTitle">{group.title}</h3>
              <div class="branchList">
                {group.pages.map((page) => (
                  <a class="pageNode" href={page.href}>
                    <span class="pageLabel">{page.label}</span>
                    <span class="pagePath">{page.href}</span>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="legend" aria-label="Diagram legend">
        <span class="legendItem"><span class="legendSwatch cyan"></span> Explore the lab's work</span>
        <span class="legendItem"><span class="legendSwatch indigo"></span> Meet people and see outputs</span>
        <span class="legendItem"><span class="legendSwatch emerald"></span> Find next steps and contact routes</span>
      </div>
    </section>
  </main>
</SiteLayout>
