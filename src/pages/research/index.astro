---
// src/pages/research/index.astro
// Research page for "Systems Structural Biology Group"
import SiteLayout from "../../layouts/SiteLayout.astro";
import { withBase as withSiteBase } from "../../lib/site";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);

const focusAreas = [
  {
    title: "Origins of life through structure and dynamics",
    text:
      "The unified theme of our laboratory is to discover the molecular origins of life by connecting structural biology, molecular biophysics, and computational discovery. We study how phenotypic outcomes such as light adaptation, growth, and immunogenicity emerge from energy transfer across crowded molecular systems."
  },
  {
    title: "Bioenergetic molecular machines",
    text:
      "A major focus is the ubiquitous family of mitochondrial protein complexes and rotatory F-/V-/A-type ATPases. We investigate their oligomeric architecture and chemomechanical coupling as exemplary biological designs for optimizing energy conversion."
  },
  {
    title: "Ageing, leakage, and disease",
    text:
      "We also examine how leakage in molecular energy networks contributes to ageing and how dysregulated turnover is implicated in disorders such as cancer and neurodegenerative disease."
  }
];

const innovationList = [
  "Atomistic molecular dynamics simulations that explicitly represent proteins, membranes, water, and interacting environments.",
  "Neural network potential-based flexible fitting for integrating imaging and structural data with simulation.",
  "Information-theoretic and geometric machine learning approaches to visualize cooperativity in molecular ensembles.",
  "ManifoldEM for learning continuous conformational transformations from single-particle images.",
  "High-performance computing and remote visualization workflows that scale across thousands of GPU and CPU nodes.",
  "Whole-cell-scale chemically accurate simulations involving hundreds of millions of interacting particles."
];

const discoveryAreas = [
  {
    title: "Mechanisms of molecular motors",
    text:
      "Using Brownian ratchet theory and molecular simulations, we unified energy storage and dissipation mechanisms across diverse classes of motors while avoiding artificial biasing assumptions that can compromise generalizability."
  },
  {
    title: "Symmetry-breaking and reversibility",
    text:
      "We found that ATPase energy turnover is regulated not simply by structure, but by controlling the tradeoff between speed and reversibility of chemomechanical transfer, revealing distinct symmetry-breaking strategies across related molecular machines."
  },
  {
    title: "From molecules to the cell",
    text:
      "Our group performed the first molecular dynamics simulation of an entire organelle, showing how cells can tune motor activity not only for efficient energy transfer but also for fitness under environmental and biochemical stress."
  },
  {
    title: "Translation to medicine",
    text:
      "During COVID-19, we identified the molecular basis of rare vaccine-associated clotting and extended this work toward immunopeptide prediction, personalized medicine, and biophysics-guided therapeutic design with clinical collaborators."
  }
];

const featuredStillImages = [
  {
    title: "Energy storage and viral surfaces",
    text:
      "From motor energetics to adenovirus surface properties, our work links physical mechanisms to biomedical function.",
    imageLeft: "uploads/brownian-ratchets-motors.png",
    imageRight: "uploads/adenovirus-surface-electrostatics.png",
    altLeft: "Brownian ratchet mechanisms across molecular motors.",
    altRight: "Surface electrostatic properties of adenovirus capsids.",
    captionLeft: "Brownian-ratchet motor mechanisms.",
    captionRight: "Electrostatic comparison of adenovirus capsids."
  },
  {
    title: "From organelles to crowded membranes",
    text:
      "We extend molecular dynamics from single molecules to organelles and dense membrane environments to study energy transfer at biological scale.",
    imageLeft: "uploads/matter-organelle-cover.png",
    imageRight: "uploads/crowded-membrane-energy-transfer.png",
    altLeft: "Whole-organelle molecular dynamics illustration.",
    altRight: "Crowded membrane energy-transfer modeling.",
    captionLeft: "Whole-organelle molecular dynamics.",
    captionRight: "Crowded membrane energy-transfer modeling."
  }
];

const relatedResearch = [
  {
    title:
      "Exploring Artificial Intelligence Tutor Teammate Adaptability to Harness Discovery Curiosity and Promote Learning in the Context of Interactive Molecular Dynamics",
    href:
      "https://link.springer.com/article/10.1007/s12559-025-10498-y",
    meta:
      "Cognitive Computation (2025)",
    description:
      "Examines how an AI tutor teammate supports curiosity, engagement, and learning during interactive molecular dynamics tasks."
  },
  {
    title:
      "Adaptive Artificial Intelligence to Teach Interactive Molecular Dynamics in the Context of Human-Computer Interaction",
    href:
      "Adaptive_Artificial_Intelligence_to_Teach_Interact.pdf",
    meta:
      "Conference paper / uploaded PDF",
    description:
      "Frames interactive molecular dynamics as a human-AI teaming context and studies adaptive AI support for curiosity and learning."
  }
];
---

<style>
  :global(html) { font-family: Arial, Helvetica, sans-serif; }
  :global(body) { background: #f6f7fb; margin: 0; color: rgba(0,0,0,.92); }

  .topbar{
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(246,247,251,.78);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .navWrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: .9rem 1.25rem;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand{
    display:inline-flex;
    align-items:center;
    gap:.75rem;
    text-decoration:none;
    color: rgba(0,0,0,.92);
    font-weight: 800;
    letter-spacing: -0.01em;
    font-size: 1.08rem;
    white-space: nowrap;
    outline: none;
  }
  .brandText strong { font-weight: 900; }

  .logoWrap{
    position: relative;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    padding: 3px;
    background:
      radial-gradient(24px 24px at 30% 20%, rgba(99,102,241,.40), transparent 65%),
      radial-gradient(28px 28px at 80% 30%, rgba(56,189,248,.35), transparent 60%),
      radial-gradient(30px 30px at 60% 85%, rgba(16,185,129,.28), transparent 62%),
      rgba(255,255,255,.60);
    border: 1px solid rgba(0,0,0,.08);
    box-shadow: 0 10px 18px rgba(0,0,0,.10);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    transform-style: preserve-3d;
    flex: 0 0 auto;
  }
  .logo{
    width:100%;
    height:100%;
    border-radius: 12px;
    object-fit: cover;
    display:block;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.80);
    transition: transform .18s ease, filter .18s ease;
  }
  .logoWrap::after{
    content:"";
    position:absolute;
    inset:-6px;
    border-radius: 18px;
    background:
      radial-gradient(circle at 30% 20%, rgba(99,102,241,.28), transparent 55%),
      radial-gradient(circle at 80% 30%, rgba(56,189,248,.22), transparent 55%),
      radial-gradient(circle at 60% 85%, rgba(16,185,129,.18), transparent 55%);
    opacity: 0;
    filter: blur(6px);
    transition: opacity .18s ease;
    pointer-events:none;
  }
  .brand:hover .logoWrap,
  .brand:focus-visible .logoWrap{
    transform: translateY(-1px) rotateX(6deg) rotateY(-8deg);
    border-color: rgba(0,0,0,.14);
    box-shadow: 0 16px 30px rgba(0,0,0,.16);
  }
  .brand:hover .logo,
  .brand:focus-visible .logo{
    transform: scale(1.02);
    filter: saturate(1.08) contrast(1.04);
  }
  .brand:hover .logoWrap::after,
  .brand:focus-visible .logoWrap::after{
    opacity: 1;
  }

  .menuBtn{
    display:none;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.85);
    border-radius: 999px;
    padding: .5rem .75rem;
    font-size: .95rem;
    cursor:pointer;
  }

  .navLinks{
    display:flex;
    align-items:center;
    gap:.35rem;
    flex-wrap: wrap;
    justify-content:flex-end;
  }
  .navA{
    text-decoration:none;
    font-size: .98rem;
    padding: .45rem .72rem;
    border-radius: 999px;
    color: rgba(0,0,0,.78);
    border: 1px solid transparent;
    transition: background .15s ease, border-color .15s ease, transform .15s ease;
  }
  .navA:hover{
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.07);
    transform: translateY(-1px);
  }
  .navA.active{
    background: rgba(0,0,0,.06);
    border-color: rgba(0,0,0,.10);
    color: rgba(0,0,0,.9);
    font-weight: 700;
  }

  @media (max-width: 820px){
    .menuBtn{ display:inline-flex; align-items:center; gap:.45rem; }
    .navLinks{ display:none; width:100%; margin-top:.75rem; }
    .navLinks.open{ display:flex; }
  }

  .wrap{
    max-width: 1440px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem 1.25rem;
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 1.4rem;
    align-items: start;
  }

  .contentNav {
    position: sticky;
    top: 84px;
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.07);
    background: rgba(255,255,255,.86);
    box-shadow: 0 10px 24px rgba(0,0,0,.06);
    padding: 1rem;
    max-height: calc(100vh - 110px);
    overflow: auto;
  }

  .contentNavTitle {
    margin: 0 0 .75rem 0;
    font-size: .92rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    font-weight: 800;
  }

  .contentNavList {
    display: grid;
    gap: .25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contentNavLink {
    display: block;
    border-radius: 10px;
    padding: .48rem .55rem;
    color: rgba(0,0,0,.72);
    text-decoration: none;
    font-size: .94rem;
    line-height: 1.35;
  }

  .contentNavLink:hover,
  .contentNavLink:focus-visible {
    background: rgba(0,0,0,.05);
    color: rgba(0,0,0,.92);
  }

  .contentColumn {
    min-width: 0;
  }

  .hero{
    border-radius: 28px;
    padding: 2.6rem 2.2rem;
    background:
      radial-gradient(1200px 520px at 12% 10%, rgba(99,102,241,.26), transparent 60%),
      radial-gradient(900px 520px at 90% 0%, rgba(56,189,248,.22), transparent 55%),
      radial-gradient(900px 520px at 50% 120%, rgba(16,185,129,.10), transparent 60%),
      linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,255,255,.78));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 18px 46px rgba(0,0,0,.09);
  }

  .kicker{
    font-size: .92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem 0;
  }
  h1{
    font-size: 3.05rem;
    line-height: 1.04;
    margin: 0 0 .85rem 0;
    letter-spacing: -0.02em;
    max-width: 14ch;
  }
  .lead{
    font-size: 1.18rem;
    line-height: 1.65;
    color: rgba(0,0,0,.74);
    max-width: 82ch;
    margin: 0;
  }

  .chips{
    display:flex;
    flex-wrap:wrap;
    gap:.6rem;
    margin-top: 1.2rem;
  }
  .chip{
    font-size: 1rem;
    padding: .5rem .8rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.76);
    color: rgba(0,0,0,.72);
  }

  .ctaRow{
    display:flex;
    flex-wrap:wrap;
    gap:.75rem;
    margin-top: 1.35rem;
  }
  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.5rem;
    padding: .72rem 1.05rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.90);
    color: rgba(0,0,0,.86);
    text-decoration:none;
    font-size: 1.02rem;
    font-weight: 700;
    transition: transform .15s ease, background .15s ease, border-color .15s ease;
  }
  .btn:hover{
    transform: translateY(-1px);
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.14);
  }
  .btn.primary{
    background: rgba(0,0,0,.92);
    color: rgba(255,255,255,.95);
    border-color: rgba(0,0,0,.92);
  }

  .grid{
    display:grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 1.25rem;
    margin-top: 1.35rem;
  }
  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
  }

  .card{
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.25rem 1.25rem 1.15rem 1.25rem;
  }
  .card h2{
    margin: 0 0 .6rem 0;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }
  .card h3{
    margin: 0 0 .4rem 0;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .card p{
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.66;
    color: rgba(0,0,0,.74);
  }

  .sectionStack{
    display:grid;
    gap: 1rem;
  }

  .subgrid{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.2rem;
  }
  @media (max-width: 760px){
    .subgrid{ grid-template-columns: 1fr; }
  }

  .feature{
    padding-top: .8rem;
    border-top: 1px solid rgba(0,0,0,.08);
  }
  .feature:first-child{
    border-top: none;
    padding-top: 0;
  }

  .list{
    margin: .8rem 0 0 0;
    padding-left: 1.05rem;
    color: rgba(0,0,0,.74);
    font-size: 1.03rem;
    line-height: 1.65;
  }
  .list li{ margin: .38rem 0; }

  .mini{
    display:grid;
    gap: 1rem;
  }
  .stat{
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.02);
    padding: 1rem 1.05rem;
  }
  .stat .label{
    font-size: .9rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .35rem 0;
  }
  .stat .value{
    font-size: 1.12rem;
    font-weight: 800;
    margin: 0;
    color: rgba(0,0,0,.86);
  }
  .stat .desc{
    margin: .45rem 0 0 0;
    color: rgba(0,0,0,.70);
    font-size: 1rem;
    line-height: 1.58;
  }

  .featuredImageSection{
    margin-top: 1.5rem;
    display: grid;
    gap: 1.25rem;
  }

  .featuredImageCard{
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.25rem;
  }

  .featuredImageGrid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
    align-items: start;
  }

  .featuredImagePanel img{
    width: 100%;
    display: block;
    border-radius: 12px;
    box-shadow: 0 2px 10px rgba(0,0,0,.12);
    background: white;
  }

  .featuredImageCaption{
    margin: .55rem 0 0 0;
    font-size: .94rem;
    line-height: 1.4;
    color: rgba(0,0,0,.58);
  }

  .featuredImageText{
    margin-top: .9rem;
  }

  .featuredImageText h3{
    margin: 0 0 .4rem 0;
    font-size: 1.35rem;
    letter-spacing: -0.01em;
  }

  .featuredImageText p{
    margin: 0;
    font-size: 1.03rem;
    line-height: 1.62;
    color: rgba(0,0,0,.74);
  }

  .relatedSection{
    margin-top: 1.5rem;
  }

  .relatedList{
    display: grid;
    gap: .9rem;
    margin-top: 1rem;
  }

  .relatedItem{
    border-top: 1px solid rgba(0,0,0,.08);
    padding-top: .9rem;
  }

  .relatedItem:first-child{
    border-top: none;
    padding-top: 0;
  }

  .relatedItem a{
    color: rgba(0,0,0,.88);
    text-decoration: none;
    font-weight: 700;
  }

  .relatedItem a:hover{
    text-decoration: underline;
  }

  .relatedMeta{
    margin-top: .2rem;
    font-size: .95rem;
    color: rgba(0,0,0,.55);
  }

  .footer{
    max-width: 1240px;
    margin: 0 auto;
    padding: 2rem 1.25rem 2.5rem 1.25rem;
    color: rgba(0,0,0,.6);
    font-size: .95rem;
  }
  .footerRow{
    display:flex;
    justify-content:space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid rgba(0,0,0,.08);
    padding-top: 1.25rem;
  }
  .footerBrand{
    display:inline-flex;
    align-items:center;
    gap:.6rem;
  }
  .footerLogo{
    width: 28px;
    height: 28px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(255,255,255,.8);
  }
  .footerLinks{
    display:flex;
    gap:.9rem;
    flex-wrap: wrap;
  }
  .footerLinks a{
    color: rgba(0,0,0,.65);
    text-decoration:none;
  }
  .footerLinks a:hover{ text-decoration: underline; }

  @media (max-width: 900px){
    .wrap {
      grid-template-columns: 1fr;
    }

    .contentNav {
      position: static;
      max-height: none;
    }

    .contentNavList {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

  }

  @media (max-width: 820px){
    .featuredImageGrid{
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px){
    .wrap{ padding: 1.6rem 1rem 2.8rem 1rem; }
    .contentNavList {
      grid-template-columns: 1fr;
    }
    .hero{ padding: 2.1rem 1.4rem; }
    h1{ font-size: 2.35rem; }
    .lead{ font-size: 1.08rem; }
    .motionText h3{ font-size: 1.7rem; }
  }
</style>

<SiteLayout title="Research | Systems Structural Biology Group">
<main class="wrap">
  <aside class="contentNav" aria-label="Research contents">
    <p class="contentNavTitle">Contents</p>
    <ol class="contentNavList">
      <li><a class="contentNavLink" href="#overview">Research overview</a></li>
      <li><a class="contentNavLink" href="#research-visuals">Featured visuals</a></li>
      <li><a class="contentNavLink" href="#related-research">Related research</a></li>
    </ol>
  </aside>

  <div class="contentColumn">
  <section class="hero">
    <p class="kicker">Research</p>
    <h1>Molecular design, dynamics, and discovery across scales.</h1>
    <p class="lead">
      Our laboratory studies the molecular origins of life by integrating structural biology,
      molecular dynamics, machine learning, and high-performance computing. We seek to understand
      how energy transfer, conformational change, and cooperative dynamics generate biological
      function, and how these principles can be translated into health, disease, and therapeutic design.
    </p>

    <div class="chips">
      <span class="chip">Molecular dynamics</span>
      <span class="chip">Structural discovery</span>
      <span class="chip">Bioenergetics</span>
      <span class="chip">Machine learning</span>
      <span class="chip">Whole-cell simulation</span>
      <span class="chip">Translational biophysics</span>
    </div>

    <div class="ctaRow">
      <a class="btn primary" href={`${base}/projects`}>See Projects</a>
      <a class="btn" href={`${base}/publications`}>View Publications</a>
      <a class="btn" href={`${base}/people`}>Collaborators & Team</a>
    </div>
  </section>

  <section id="overview" class="grid" aria-label="Research overview">
    <div class="sectionStack">
      <div class="card">
        <h2>Research theme</h2>
        <p>
          The unified theme of the lab is to discover the molecular origins of life. This mission
          bridges structural biology, computation, and quantitative modeling to reveal the design
          principles underlying biomolecular function.
        </p>

        <div class="subgrid">
          {focusAreas.map((item) => (
            <div class="feature">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="card">
        <h2>Innovations</h2>
        <p>
          The primary methodological foundation of our program is atomistic molecular dynamics,
          paired with machine learning, image-based inference, and scalable computation. These tools
          allow us to probe the noisy coupling between rapid chemical reactions, slower conformational
          transitions, and even slower diffusive processes across biological systems.
        </p>
        <ul class="list">
          {innovationList.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="card">
        <h2>Discoveries and impact</h2>
        <p>
          Our work has contributed new mechanistic insight into molecular motors, organelle-scale
          energy transfer, and biophysical causes of disease. Across these studies, the common aim is
          to connect fundamental physical principles with functional and translational relevance.
        </p>

        <div class="sectionStack" style="margin-top: 1rem;">
          {discoveryAreas.map((item) => (
            <div class="feature">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mini">
      <div class="stat">
        <p class="label">Core question</p>
        <p class="value">How does life emerge from interacting molecular systems?</p>
        <p class="desc">
          We study how structure, dynamics, and energy flow together produce biological function across scales.
        </p>
      </div>

      <div class="stat">
        <p class="label">Signature methods</p>
        <p class="value">MD, ManifoldEM, and interpretable machine learning</p>
        <p class="desc">
          Our group integrates structural, imaging, and kinetic data into physically grounded models of biomolecular behavior.
        </p>
      </div>

      <div class="stat">
        <p class="label">Computational scale</p>
        <p class="value">From single molecules to organelles and cell-scale models</p>
        <p class="desc">
          National supercomputing resources allow our computations to reach hundreds of millions of particles.
        </p>
      </div>

      <div class="stat">
        <p class="label">Translation</p>
        <p class="value">Biophysics-guided medicine and therapeutic design</p>
        <p class="desc">
          We extend simulation-based discovery into immunology, vaccine safety, cancer, and personalized health applications.
        </p>
      </div>
    </div>
  </section>

  <section id="research-visuals" class="featuredImageSection" aria-label="Featured research visuals">
    {featuredStillImages.map((item) => (
      <article class="featuredImageCard">
        <div class="featuredImageGrid">
          <div class="featuredImagePanel">
            <img src={withBase(item.imageLeft)} alt={item.altLeft} loading="lazy" />
            <p class="featuredImageCaption">{item.captionLeft}</p>
          </div>
          <div class="featuredImagePanel">
            <img src={withBase(item.imageRight)} alt={item.altRight} loading="lazy" />
            <p class="featuredImageCaption">{item.captionRight}</p>
          </div>
        </div>
        <div class="featuredImageText">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </div>
      </article>
    ))}
  </section>

  <section id="related-research" class="relatedSection" aria-label="Related research">
    <div class="card">
      <p class="kicker">Related research</p>
      <h2>Selected work connected to this program</h2>

      <div class="relatedList">
        {relatedResearch.map((item) => (
          <div class="relatedItem">
            <a
              href={withBase(item.href)}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              {item.title}
            </a>
            <div class="relatedMeta">{item.meta}</div>
            <p style="margin-top:.35rem;">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  </div>
</main>
</SiteLayout>
